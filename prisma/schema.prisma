generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
model User {
  id                  String               @id @default(uuid())
  name                String?
  email               String
  phone               String?
  password            String
  role                UserRole
  joinDate            DateTime              @default(now())
  status              Status
}



model Messages {
  id                  String               @id @default(uuid())
  name                String
  email               String
  phone               String
  subject             String
  message             String               @db.Text  
  date                DateTime              @default(now())
  read                Boolean               @default(false)
}


model Accounts {
  id                  String               @id @default(uuid())
  platform            String
  url                 String
  icon                String?
  status              AccountStatus
  createdAt           DateTime              @default(now())
}

model blogs {
  id                  String               @id @default(uuid())
  slug                String
  title               String
  excerpt             String
  content             String              @db.Text  
  author              String
  date                DateTime              @default(now())
  image               String
}


enum AccountStatus {
  active
  inactive
}

enum Status {
  active
  inactive
}

enum UserRole {
  admin
  editor
}